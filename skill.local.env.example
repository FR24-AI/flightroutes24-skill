# 复制为 skill.local.env（仅固定网关；勿提交 git）
# 采购 CID / 密钥请用系统或用户环境变量，不要写在本文件

FR_SKILL_EXPORT_BASE_URL=https://flight-deve.flightroutes24.com
FR_SKILL_GRAY_HEADER=ww

# 以下请配置在 Windows「用户环境变量」或当前终端，不要写入 skill.local.env：
# FR_NEWAPI_APPKEY=你的采购APPKEY
# FR_NEWAPI_SIGN_SECRET=SHA512签名密钥
# FR_NEWAPI_AES_SECRET=16字节AES密钥
# FR_NEWAPI_SKIP_IP_WHITELIST=1   # 仅 deve 联调可选
# FR_NEWAPI_SKIP_AUTH=1           # 仅 deve 联调可选
